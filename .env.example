# =============================================================================
# FamilyHub Environment Variables
# =============================================================================
# Copy this file to .env.local for local development
# Vite only exposes variables prefixed with VITE_ to the client
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------

# PocketBase URL for browser SDK requests.
# Default in code: "http://127.0.0.1:8090"
# Run `npm run setup` to download the local PocketBase binary, create the
# development admin account, apply collections, and seed demo credentials.
# Examples:
#   - "http://127.0.0.1:8090" for local PocketBase
#   - "https://pb.familyhub.example.com" for hosted PocketBase
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# Local PocketBase setup defaults. These are used by `npm run setup` and are
# intentionally for local development only.
PB_ADMIN_EMAIL=admin@digital-parent.local
PB_ADMIN_PASSWORD=digital-parent-admin-123
PB_APP_USERNAME=family
PB_APP_PASSWORD=password123

# -----------------------------------------------------------------------------
# Development/Testing Flags
# -----------------------------------------------------------------------------

# E2E testing mode
# - Disables TanStack Query DevTools
# - Reduces simulated API delays for faster tests
# Set by Playwright automatically; don't set manually
# VITE_E2E=true

# -----------------------------------------------------------------------------
# localStorage Keys Reference
# -----------------------------------------------------------------------------
# family-hub-calendar-events  - Calendar events (API cache)
# family-hub-calendar-ui      - Calendar UI preferences (Zustand persist)
